# Copy this file to .env.local for local development, and set the same keys as
# Environment Variables in your host (e.g. Vercel) for production.
# See README.md for full setup.

# Google Cloud OAuth client (APIs & Services > Credentials).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Session encryption secret. Generate one with: openssl rand -base64 32
AUTH_SECRET=

# The app's own URL. Locally this is http://localhost:3000.
# In production set it to your real domain, e.g. https://events.example.com
AUTH_URL=http://localhost:3000

# The Google Drive "Events" folder. Set the ID directly (preferred), or leave it
# blank and set EVENTS_FOLDER_NAME to look it up by name (defaults to "Events").
EVENTS_FOLDER_ID=
# EVENTS_FOLDER_NAME=Events

# The members Google Sheets used by the Birthdays page. Paste the full sheet URL
# (https://docs.google.com/spreadsheets/d/THE_ID/edit) or just THE_ID.
# NEW: must have "Nama Lengkap/ Full Name" + "Ulang Tahun/ Birthday" (full date).
# OLD (optional, legacy): "Nama Lengkap" + "Birthday" (e.g. 17-Feb-1997).
BIRTHDAY_SHEET_ID_NEW=
BIRTHDAY_SHEET_ID_OLD=
